{
  "name": "emory.apstudy",
  "version": "1.0.0",
  "description": "Startup command: ```if [[ -f /home/container/requirements.txt ]]; then pip install -U --prefix .local -r requirements.txt; fi; SCHEDULER_ENABLED=1 python -m gunicorn -w 1 -b 0.0.0.0:${SERVER_PORT} \"app:create_app()\"```",
  "main": "atlasMainScraper.js",
  "scripts": {
    "scrape:atlas": "node atlasMainScraper.js",
    "build:css": "tailwindcss -c ./tailwind.config.cjs -i ./static/css/tailwind-input.css -o ./static/css/tailwind.css --minify",
    "build:notes": "vite build --config vite.notes.config.mjs",
    "build": "npm run build:css && npm run build:notes",
    "watch:css": "tailwindcss -c ./tailwind.config.cjs -i ./static/css/tailwind-input.css -o ./static/css/tailwind.css --watch",
    "test": "npm run test:js && npm run test:py",
    "test:js": "node --test tests/js/*.test.cjs tests/js/*.test.mjs",
    "test:py": "python -m unittest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimpleLemon/emory.apstudy.git"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SimpleLemon/emory.apstudy/issues"
  },
  "homepage": "https://github.com/SimpleLemon/emory.apstudy#readme",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "jscpd": "^5.0.4",
    "playwright": "^1.60.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@blocknote/core": "^0.28.0",
    "@blocknote/mantine": "^0.28.0",
    "@blocknote/react": "^0.28.0",
    "@mantine/core": "^8.2.8",
    "@mantine/hooks": "^8.2.8",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-history": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "appwrite": "^25.0.0",
    "cmdk": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
