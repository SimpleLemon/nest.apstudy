{
  "course_code": "PSYC 499R",
  "course_title": "Directed Research",
  "subject": "PSYC",
  "catalog_number": "499R",
  "term": "Spring_2026",
  "srcdb": "5261",
  "credit_hours": "3",
  "requirement_designation": "XA",
